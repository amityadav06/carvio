Prisma queries equvilant to postgres or sql queries for reference

-- =========================
-- ENUMS
-- =========================

CREATE TYPE user_role AS ENUM (
    'USER',
    'ADMIN'
);

CREATE TYPE car_status AS ENUM (
    'AVILABLE',
    'UNAVILABLE',
    'SOLD'
);

CREATE TYPE day_of_week AS ENUM (
    'MONDAY',
    'TUESDAY',
    'WEDNESDAY',
    'THURSDAY',
    'FRIDAY',
    'SATURDAY',
    'SUNDAY'
);

CREATE TYPE booking_status AS ENUM (
    'PENDING',
    'CONFIRMED',
    'COMPLETED',
    'CANCELLED',
    'NO_SHOW'
);

-- =========================
-- USERS
-- =========================

CREATE TABLE users (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    clerk_user_id VARCHAR(255) UNIQUE NOT NULL,
    email VARCHAR(255) UNIQUE NOT NULL,
    name VARCHAR(255) NOT NULL,
    image_url TEXT NOT NULL,
    phone VARCHAR(50) NOT NULL,
    role user_role DEFAULT 'USER',
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- =========================
-- CARS
-- =========================

CREATE TABLE cars (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    make VARCHAR(100) NOT NULL,
    model VARCHAR(100) NOT NULL,
    year INT NOT NULL,
    price DECIMAL(10,2) NOT NULL,
    mileage INT NOT NULL,
    color VARCHAR(100) NOT NULL,
    fuel_type VARCHAR(100) NOT NULL,
    transmission VARCHAR(100) NOT NULL,
    body_type VARCHAR(100) NOT NULL,
    seats INT,
    description TEXT NOT NULL,
    status car_status DEFAULT 'AVILABLE',
    featured BOOLEAN DEFAULT FALSE,
    images TEXT[],
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- =========================
-- DEALERSHIP
-- =========================

CREATE TABLE dealership_info (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    name VARCHAR(255) DEFAULT 'Carvio Motors',
    address TEXT DEFAULT '69 Car Street, Antelia',
    phone VARCHAR(50) DEFAULT '+1 (555) 8379682',
    email VARCHAR(255) DEFAULT 'contact@carvio.com',
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- =========================
-- WORKING HOURS
-- =========================

CREATE TABLE working_hours (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    dealership_id UUID NOT NULL,
    day_of_week day_of_week NOT NULL,
    open_time VARCHAR(10) NOT NULL,
    close_time VARCHAR(10) NOT NULL,
    is_open BOOLEAN DEFAULT TRUE,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,

    CONSTRAINT fk_dealership
        FOREIGN KEY (dealership_id)
        REFERENCES dealership_info(id)
        ON DELETE CASCADE,

    CONSTRAINT unique_day UNIQUE(dealership_id, day_of_week)
);

-- =========================
-- USER SAVED CARS
-- =========================

CREATE TABLE user_saved_cars (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    user_id UUID NOT NULL,
    car_id UUID NOT NULL,
    saved_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,

    CONSTRAINT fk_saved_user
        FOREIGN KEY(user_id)
        REFERENCES users(id)
        ON DELETE CASCADE,

    CONSTRAINT fk_saved_car
        FOREIGN KEY(car_id)
        REFERENCES cars(id)
        ON DELETE CASCADE,

    CONSTRAINT unique_saved UNIQUE(user_id, car_id)
);

-- =========================
-- TEST DRIVE BOOKINGS
-- =========================

CREATE TABLE test_drive_bookings (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),

    user_id UUID NOT NULL,
    car_id UUID NOT NULL,

    booking_date DATE NOT NULL,
    start_time VARCHAR(10) NOT NULL,
    end_time VARCHAR(10) NOT NULL,

    status booking_status DEFAULT 'PENDING',
    notes TEXT,

    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,

    CONSTRAINT fk_booking_user
        FOREIGN KEY(user_id)
        REFERENCES users(id)
        ON DELETE CASCADE,

    CONSTRAINT fk_booking_car
        FOREIGN KEY(car_id)
        REFERENCES cars(id)
        ON DELETE CASCADE
);

-- =========================
-- INDEXES
-- =========================

-- Cars
CREATE INDEX idx_car_make_model ON cars(make, model);
CREATE INDEX idx_car_body_type ON cars(body_type);
CREATE INDEX idx_car_price ON cars(price);
CREATE INDEX idx_car_year ON cars(year);
CREATE INDEX idx_car_status ON cars(status);
CREATE INDEX idx_car_fuel_type ON cars(fuel_type);
CREATE INDEX idx_car_featured ON cars(featured);

-- Working Hours
CREATE INDEX idx_wh_dealership ON working_hours(dealership_id);
CREATE INDEX idx_wh_day ON working_hours(day_of_week);
CREATE INDEX idx_wh_open ON working_hours(is_open);

-- Saved Cars
CREATE INDEX idx_saved_user ON user_saved_cars(user_id);
CREATE INDEX idx_saved_car ON user_saved_cars(car_id);

-- Test Drive Bookings
CREATE INDEX idx_booking_car ON test_drive_bookings(car_id);
CREATE INDEX idx_booking_user ON test_drive_bookings(user_id);
CREATE INDEX idx_booking_date ON test_drive_bookings(booking_date);
CREATE INDEX idx_booking_status ON test_drive_bookings(status);